# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# bundled scheduler output (built inside the Docker image)
/dist

# database
/data

# playwright e2e (isolated DB, saved auth state, reports/artifacts)
/e2e/.data
/e2e/.auth
/test-results
/playwright-report
/blob-report
/playwright/.cache

# local claude settings
.claude/settings.local.json

# PHI-scan optional denylist of real names/orgs (see scripts/phi-scan.ts).
# Must never be committed — it would itself introduce PHI.
.phi-denylist
