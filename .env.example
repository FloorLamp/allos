# Copy this file to .env.local for local dev (Next.js loads it automatically), or
# to .env for Docker (docker-compose reads .env). Both are gitignored.

# Enables Claude-powered insights and medical-document extraction.
# Without it (and without AI_BASE_URL), insights fall back to an offline summary
# and uploaded documents are stored but marked "skipped" (no extraction).
ANTHROPIC_API_KEY=sk-ant-...

# Optional: point the app at a local / self-hosted inference server exposing an
# Anthropic-compatible API (Ollama, a proxy, …) for zero external egress — no
# request leaves the box beyond this endpoint. Local servers usually ignore the
# key, so ANTHROPIC_API_KEY is optional when this is set. AI counts as configured
# when EITHER this or the key is present.
# AI_BASE_URL=http://localhost:11434

# Optional: override the model used for AI features (defaults to claude-sonnet-5).
# HEALTH_AI_MODEL=claude-opus-4-8

# Optional AI usage caps / extraction concurrency guards (defaults shown):
# AI_DAILY_EXTRACTION_LIMIT   max medical-document extractions per day (default 50)
# AI_DAILY_INSIGHT_LIMIT      max AI insight generations per day (default 100)
# AI_EXTRACTION_CONCURRENCY   how many extractions run at once (default 3)
# AI_EXTRACTION_QUEUE_MAX     max extractions queued behind the running ones (default 100)
# EXTRACTION_LEASE_MINUTES    how long a claimed extraction lease is held (default 30)
# AI_DAILY_EXTRACTION_LIMIT=50
# AI_DAILY_INSIGHT_LIMIT=100
# AI_EXTRACTION_CONCURRENCY=3
# AI_EXTRACTION_QUEUE_MAX=100
# EXTRACTION_LEASE_MINUTES=30

# Optional: max output tokens for medical-document extraction (default 16000).
# HEALTH_AI_MAX_TOKENS=16000

# --- Bootstrap admin ---
# The first-boot admin login, created ONLY when the DB has no logins yet (on an
# existing instance these are ignored). ADMIN_USERNAME defaults to "admin"; if
# ADMIN_PASSWORD is unset a random one is generated and logged once at startup —
# set it here so you know the password up front.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me-on-first-login

# --- Auth / 2FA recovery ---
# Bootstrap-recovery escape hatch for TOTP two-factor auth. Comma-separated
# username(s) whose second factor is SKIPPED at login — use only to let an admin
# back in after they lose their authenticator AND recovery codes. Every bypass is
# logged loudly and audited (login.2fa-bypass). Remove it and re-enroll once
# access is restored.
# ALLOS_DISABLE_2FA=admin

# --- Public demo instance (#181) ---
# Set to 1 to run this instance as a PUBLIC, read-only demo: the login page shows
# the demo credentials, a persistent "synthetic data — do not enter real health
# information" banner appears on every page, and every NON-admin write is refused
# (the demo login is a read-only member). Leave UNSET for any real deployment.
# NEVER co-host a demo instance with a real family instance — see README.
# ALLOS_DEMO_MODE=1

# --- Logging ---
# Verbosity: debug | info | warn | error (default info).
# LOG_LEVEL=info
# Format: text | json. Defaults to text in dev, json in production.
# LOG_FORMAT=json
# Set to 0 to keep prompts/responses out of the AI activity log (data/logs/ai.jsonl).
# AI_LOG_PROMPTS=1

# --- Integrations ---
# Headless-bootstrap-only fallback bearer token for the Health Connect ingest
# endpoint (/api/integrations/health-connect/ingest), mapped to profile 1.
# Normally you generate the token in the UI (Data → Import → Google Health
# Connect), where you can rotate it, set an optional expiry, and see last-used;
# the UI-generated token takes precedence. A token set here has NO expiry,
# rotation, or last-used tracking, so prefer a DB-backed token once the app is
# reachable.
# HEALTH_CONNECT_TOKEN=

# --- Deployment (Docker) ---
# Host port to expose the app on (container always listens on 3000).
# PORT=3000
# Set this when the app runs BEHIND A REVERSE PROXY that sets X-Forwarded-For.
# Only then does the Telegram-webhook rate limiter trust that header to key its
# per-client budget; left unset (direct-to-Node exposure), the header is spoofable
# so all webhook traffic shares one bucket. No effect on authentication.
# TRUST_PROXY=1
# Timezone is set in the app (Settings → Profile) and stored in the DB — no env
# needed. It defaults to UTC until you choose one; if a TZ env happens to be set on
# first boot, it's used as the initial value (one-time migration only).
# Where persistent data (SQLite DB, uploads, AI log) is stored on the host. Make it
# an ABSOLUTE path OUTSIDE the repo checkout so a `docker compose pull && up -d`
# never risks an in-repo ./data.
# DATA_DIR=/srv/allos/data
# Off-volume backup destination: a SECOND mounted directory (a NAS, another disk,
# a synced folder) on a DIFFERENT volume than DATA_DIR. After each verified
# snapshot the app copies it there and mirrors data/uploads/, so a loss of the
# DATA_DIR volume doesn't take every backup with it. Holds multi-profile PHI —
# keep it operator-controlled (no cloud/network target is built in). See the
# README "Backups → Off-volume backups" section.
# BACKUP_DEST_DIR=/backup
