# Copy this file to .env.local for local dev (Next.js loads it automatically), or
# to .env for Docker (docker-compose reads .env). Both are gitignored.

# Enables Claude-powered insights and medical-document extraction.
# Without it, insights fall back to an offline summary and uploaded
# documents are stored but marked "skipped" (no extraction).
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used for AI features (defaults to claude-sonnet-4-6).
# HEALTH_AI_MODEL=claude-opus-4-8

# Optional: max output tokens for medical-document extraction (default 16000).
# HEALTH_AI_MAX_TOKENS=16000

# --- Logging ---
# Verbosity: debug | info | warn | error (default info).
# LOG_LEVEL=info
# Format: text | json. Defaults to text in dev, json in production.
# LOG_FORMAT=json
# Set to 0 to keep prompts/responses out of the AI activity log (data/logs/ai.jsonl).
# AI_LOG_PROMPTS=1

# --- Integrations ---
# Optional fallback bearer token for the Health Connect ingest endpoint
# (/api/integrations/health-connect/ingest). Normally you generate the token in
# the UI (Integrations → Google Health Connect); a token set here is used only as
# a fallback for headless setups, and the UI-generated token takes precedence.
# HEALTH_CONNECT_TOKEN=

# --- Deployment (Docker) ---
# Host port to expose the app on (container always listens on 3000).
# PORT=3000
# Timezone is set in the app (Settings → Timezone) and stored in the DB — no env
# needed. It defaults to UTC until you choose one; if a TZ env happens to be set on
# first boot, it's used as the initial value (one-time migration only).
# Where persistent data (SQLite DB, uploads, AI log) is stored on the host.
# For the self-hosted-runner CD setup this MUST be an ABSOLUTE path OUTSIDE the
# repo (the deploy checkout would otherwise wipe an in-repo ./data).
# DATA_DIR=/srv/allos/data
