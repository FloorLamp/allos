
# sha256 hex digests of migration files — digit runs can coincidentally Luhn-validate
# as NPI-shaped numbers; the file contains only content hashes, never identifiers.
lib/migrations/manifest.json

# US Census ZCTA (ZIP → coarse centroid) public-domain gazetteer, generated by
# scripts/gen-zip-centroids.ts. A COMPLETE ZIP table necessarily contains every real
# ZIP — including one a local .phi-denylist lists as a home ZIP — but these are public
# reference coordinates (rounded to ~0.1°), never a person's data.
lib/zip-centroids.json
